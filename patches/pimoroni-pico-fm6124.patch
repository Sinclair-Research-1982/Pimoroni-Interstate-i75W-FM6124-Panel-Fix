+void Hub75::start_dma_for_row() {
+    Pixel *source = &back_buffer[row * width * 2];
+    Pixel *dma_source = source;
+
+    if (dma_prepend_extra_columns > 0 && dma_row_buffer != nullptr) {
+        uint prepend_words = dma_prepend_extra_columns * 2;
+        std::fill_n(dma_row_buffer, prepend_words, Pixel(0));
+        std::copy_n(source, width * 2, dma_row_buffer + prepend_words);
+        dma_source = dma_row_buffer;
+    } else if (dma_prepend_columns > 0 && dma_row_buffer != nullptr) {
+        uint prepend_words = dma_prepend_columns * 2;
+        uint copy_words = (width - dma_prepend_columns) * 2;
+        std::fill_n(dma_row_buffer, prepend_words, Pixel(0));
+        std::copy_n(source, copy_words, dma_row_buffer + prepend_words);
+        dma_source = dma_row_buffer;
+    } else if (dma_advance_columns > 0 && dma_row_buffer != nullptr) {
+        uint advance_words = dma_advance_columns * 2;
+        uint copy_words = (width - dma_advance_columns) * 2;
+        std::copy_n(source + advance_words, copy_words, dma_row_buffer);
+        std::fill_n(dma_row_buffer + copy_words, advance_words, Pixel(0));
+        dma_source = dma_row_buffer;
+    }
+
+    dma_channel_set_trans_count(dma_channel, dma_transfer_words, false);
+    dma_channel_set_read_addr(dma_channel, dma_source, true);
+}
